            <div class="page">
                <h2><t t-set="es" t-value="'Informe de no conformidad (proveedor)'"/><t t-set="en" t-value="'Nonconformity Report (supplier)'"/><t t-call="sid_nonconformity.report_sid_nc_label"/> - <span t-field="o.name"/></h2>
