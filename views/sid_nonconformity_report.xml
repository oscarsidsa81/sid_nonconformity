<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_sid_nonconformity_internal" model="ir.actions.report">
        <field name="name">Nonconformity Report (internal)</field>
        <field name="model">sid.nonconformity</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sid_nonconformity.report_sid_nonconformity_document_internal</field>
        <field name="report_file">sid_nonconformity.report_sid_nonconformity_document_internal</field>
        <field name="print_report_name">'NC-%s-%s-internal' % (object.name, object.state)</field>
        <field name="binding_model_id" ref="model_sid_nonconformity"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_sid_nonconformity_customer" model="ir.actions.report">
        <field name="name">Nonconformity Report (customer)</field>
        <field name="model">sid.nonconformity</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sid_nonconformity.report_sid_nonconformity_document_customer</field>
        <field name="report_file">sid_nonconformity.report_sid_nonconformity_document_customer</field>
        <field name="print_report_name">'NC-%s-%s-customer' % (object.name, object.state)</field>
        <field name="binding_model_id" ref="model_sid_nonconformity"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_sid_nonconformity_supplier" model="ir.actions.report">
        <field name="name">Nonconformity Report (supplier)</field>
        <field name="model">sid.nonconformity</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sid_nonconformity.report_sid_nonconformity_document_supplier</field>
        <field name="report_file">sid_nonconformity.report_sid_nonconformity_document_supplier</field>
        <field name="print_report_name">'NC-%s-%s-supplier' % (object.name, object.state)</field>
        <field name="binding_model_id" ref="model_sid_nonconformity"/>
        <field name="binding_type">report</field>
    </record>

    <record id="server_action_print_sid_nonconformity_internal" model="ir.actions.server">
        <field name="name">Print Nonconformity Report (internal)</field>
        <field name="model_id" ref="model_sid_nonconformity"/>
        <field name="binding_model_id" ref="model_sid_nonconformity"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('sid_nonconformity.action_report_sid_nonconformity_internal').report_action(records)</field>
    </record>

    <record id="server_action_print_sid_nonconformity_customer" model="ir.actions.server">
        <field name="name">Print Nonconformity Report (customer)</field>
        <field name="model_id" ref="model_sid_nonconformity"/>
        <field name="binding_model_id" ref="model_sid_nonconformity"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('sid_nonconformity.action_report_sid_nonconformity_customer').report_action(records)</field>
    </record>

    <record id="server_action_print_sid_nonconformity_supplier" model="ir.actions.server">
        <field name="name">Print Nonconformity Report (supplier)</field>
        <field name="model_id" ref="model_sid_nonconformity"/>
        <field name="binding_model_id" ref="model_sid_nonconformity"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('sid_nonconformity.action_report_sid_nonconformity_supplier').report_action(records)</field>
    </record>

    <template id="report_sid_nc_label">
        <t t-if="is_es"><t t-esc="es"/></t><t t-else=""><t t-esc="en"/></t>
    </template>

    <template id="report_sid_nonconformity_document_internal">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="doc_lang" t-value="env.user.lang or 'en_US'"/>
                <t t-call="sid_nonconformity.report_sid_nonconformity_document_internal_body" t-lang="doc_lang"/>
            </t>
        </t>
    </template>

    <template id="report_sid_nonconformity_document_internal_body">
        <t t-set="o" t-value="o.with_context(lang=doc_lang)"/>
        <t t-set="is_es" t-value="doc_lang and doc_lang[:2] == 'es'"/>
        <t t-call="web.external_layout">
            <div class="page">
                <style>
                    .nc-ribbon-wrap { position: relative; min-height: 42px; }
                    .nc-state-ribbon {
                        position: absolute;
                        top: 0;
                        right: 0;
                        padding: 4px 14px;
                        color: #ffffff;
                        font-weight: 700;
                        border-radius: 0 0 0 8px;
                        text-transform: uppercase;
                        font-size: 11px;
                        letter-spacing: 0.4px;
                    }
                    .nc-state-ribbon.draft { background-color: #6c757d; }
                    .nc-state-ribbon.open { background-color: #0d6efd; }
                    .nc-state-ribbon.action { background-color: #fd7e14; }
                    .nc-state-ribbon.verify { background-color: #6f42c1; }
                    .nc-state-ribbon.done { background-color: #198754; }
                    .nc-state-ribbon.cancel { background-color: #dc3545; }
                </style>

                <div class="nc-ribbon-wrap">
                    <div t-attf-class="nc-state-ribbon {{ o.state }}">
                        <span t-field="o.state"/>
                    </div>
                </div>

                <h2><t t-set="es" t-value="'Informe de no conformidad'"/><t t-set="en" t-value="'Nonconformity Report'"/><t t-call="sid_nonconformity.report_sid_nc_label"/> - <span t-field="o.name"/></h2>
                <p><strong><t t-set="es" t-value="'Fase actual'"/><t t-set="en" t-value="'Current phase'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.state"/></p>
                <table class="table table-sm o_main_table">
                    <tbody>
                        <tr><td><strong><t t-set="es" t-value="'Título'"/><t t-set="en" t-value="'Title'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.title"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Tipo'"/><t t-set="en" t-value="'Type'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.nc_type"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Alcance ISO'"/><t t-set="en" t-value="'ISO Scope'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.iso_scope"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Importancia'"/><t t-set="en" t-value="'Severity'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.severity"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Prioridad'"/><t t-set="en" t-value="'Priority'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.priority"/></td></tr>
                        <tr t-if="o.sale_id"><td><strong><t t-set="es" t-value="'Referencia del pedido de cliente'"/><t t-set="en" t-value="'Sales Order Reference'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.sale_id"/></td></tr>
                        <tr t-if="o.supplier_id"><td><strong><t t-set="es" t-value="'Proveedor'"/><t t-set="en" t-value="'Supplier'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.supplier_id"/></td></tr>
                        <tr t-if="o.customer_id"><td><strong><t t-set="es" t-value="'Cliente'"/><t t-set="en" t-value="'Customer'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.customer_id"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Responsable'"/><t t-set="en" t-value="'Responsible'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.user_id"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Fecha de detección'"/><t t-set="en" t-value="'Detection Date'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.date_detected"/></td></tr>
                        <tr><td><strong><t t-set="es" t-value="'Fecha límite'"/><t t-set="en" t-value="'Deadline'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></strong></td><td><span t-field="o.date_deadline"/></td></tr>
                    </tbody>
                </table>

                <h4><t t-set="es" t-value="'Avance por fase'"/><t t-set="en" t-value="'Phase Progress'"/><t t-call="sid_nonconformity.report_sid_nc_label"/></h4>
                <p><strong><t t-set="es" t-value="'Descripción / evidencia'"/><t t-set="en" t-value="'Description / Evidence'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.description"/></p>
                <p><strong><t t-set="es" t-value="'Contención inmediata'"/><t t-set="en" t-value="'Immediate Containment'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.containment_action"/></p>
                <p><strong><t t-set="es" t-value="'Causa raíz'"/><t t-set="en" t-value="'Root Cause'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.root_cause"/></p>
                <p><strong><t t-set="es" t-value="'Acción correctiva'"/><t t-set="en" t-value="'Corrective Action'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.corrective_action"/></p>
                <p><strong><t t-set="es" t-value="'Acción preventiva'"/><t t-set="en" t-value="'Preventive Action'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.preventive_action"/></p>
                <p><strong><t t-set="es" t-value="'Verificación de eficacia'"/><t t-set="en" t-value="'Effectiveness Check'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.effectiveness_check"/></p>
                <p><strong><t t-set="es" t-value="'Notas de cierre internas'"/><t t-set="en" t-value="'Internal Closing Notes'"/><t t-call="sid_nonconformity.report_sid_nc_label"/>:</strong> <span t-field="o.closing_notes_internal"/></p>
            </div>
        </t>
    </template>

