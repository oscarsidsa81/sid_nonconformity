<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_sid_nonconformity" model="ir.ui.view">
        <field name="name">purchase.order.form.sid.nonconformity</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sid_nonconformities" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
                    <field name="sid_nonconformity_count" widget="statinfo" string="NCs"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_sid_nonconformity" type="object" string="Create NC" class="btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
