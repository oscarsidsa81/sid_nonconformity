<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sid_nonconformity_tree" model="ir.ui.view">
        <field name="name">sid.nonconformity.tree</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <tree decoration-danger="is_overdue" decoration-muted="state in ('done', 'cancel')">
                <field name="name"/>
                <field name="title"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state in ('open', 'action', 'verify')" decoration-warning="state == 'draft'" decoration-danger="state == 'cancel'"/>
                <field name="nc_type"/>
                <field name="iso_scope"/>
                <field name="severity"/>
                <field name="priority"/>
                <field name="partner_id" domain="[('is_company', '=', True)]"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <field name="date_detected"/>
                <field name="date_deadline"/>
                <field name="is_overdue"/>
            </tree>
        </field>
    </record>

    <record id="view_sid_nonconformity_kanban" model="ir.ui.view">
        <field name="name">sid.nonconformity.kanban</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="title"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="severity"/>
                <field name="partner_id" domain="[('is_company', '=', True)]"/>
                <field name="user_id"/>
                <field name="date_deadline"/>
                <field name="is_overdue"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record #{record.is_overdue.raw_value ? 'oe_kanban_color_2' : ''}">
                            <strong><field name="name"/> - <field name="title"/></strong>
                            <div><field name="nc_type"/> / <field name="severity"/></div>
                            <div t-if="record.partner_id.raw_value"><field name="partner_id" domain="[('is_company', '=', True)]"/></div>
                            <div t-if="record.date_deadline.raw_value">Deadline: <field name="date_deadline"/></div>
                            <div class="oe_kanban_footer">
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sid_nonconformity_search" model="ir.ui.view">
        <field name="name">sid.nonconformity.search</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="partner_id" domain="[('is_company', '=', True)]"/>
                <field name="product_id"/>
                <field name="purchase_id" domain="[('partner_id', '=', partner_id)]"/>
                <field name="sale_id" domain="[('id', 'in', available_sale_order_ids)]"/>
                <field name="picking_id" domain="['|', ('sale_id', '=', sale_id), ('purchase_id', '=', purchase_id)]"/>
                <filter name="open" string="Open" domain="[('state', 'not in', ('done', 'cancel'))]"/>
                <filter name="overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                <filter name="my_nc" string="My NCs" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="iso9001" string="ISO 9001" domain="[('iso_scope', 'in', ('iso_9001', 'integrated'))]"/>
                <filter name="iso14001" string="ISO 14001" domain="[('iso_scope', 'in', ('iso_14001', 'integrated'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'nc_type'}"/>
                    <filter name="group_partner" string="Customer / Supplier" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_responsible" string="Responsible" context="{'group_by': 'user_id'}"/>
                    <filter name="group_month" string="Detection Month" context="{'group_by': 'date_detected:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sid_nonconformity_form" model="ir.ui.view">
        <field name="name">sid.nonconformity.form</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <form string="Nonconformity">
                <header>
                    <button name="action_open" type="object" string="Open" states="draft" class="oe_highlight"/>
                    <button name="action_start_action" type="object" string="Start Corrective Action" states="open" class="oe_highlight"/>
                    <button name="action_verify" type="object" string="Verify Effectiveness" states="action" class="oe_highlight"/>
                    <button name="action_close" type="object" string="Close" states="action,verify" class="oe_highlight"/>
                    <button name="action_cancel" type="object" string="Cancel" states="draft,open,action,verify"/>
                    <button name="action_previous_phase" type="object" string="Previous Phase" states="open,action,verify,done"/>
                    <button name="%(action_report_sid_nonconformity)d" type="action" string="Print Phase PDF" class="btn-secondary"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" states="cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,action,verify,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attachments" type="object" class="oe_stat_button" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo" string="Attachments"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="title" placeholder="Short description of the nonconformity"/></h2>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="iso_scope"/>
                            <field name="nc_type"/>
                            <field name="severity"/>
                            <field name="priority"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                        <group string="Responsibility and Dates">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="reviewer_id" widget="many2one_avatar_user"/>
                            <field name="date_detected"/>
                            <field name="date_deadline"/>
                            <field name="date_closed" readonly="1"/>
                            <field name="days_to_close" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Origin">
                            <group>
                                <group string="Operational Links">
                                    <field name="partner_id" domain="[('is_company', '=', True)]"/>
                                    <field name="purchase_id" domain="[('partner_id', '=', partner_id)]"/>
                                    <field name="sale_id" domain="[('id', 'in', available_sale_order_ids)]"/>
                                    <field name="picking_id" domain="['|', ('sale_id', '=', sale_id), ('purchase_id', '=', purchase_id)]"/>
                                    <field name="move_line_id" domain="[('picking_id', '=', picking_id)]"/>
                                </group>
                                <group string="Product / Impact">
                                    <field name="product_id"/>
                                    <field name="lot_id" domain="[('product_id', '=', product_id)]"/>
                                    <field name="quantity_affected"/>
                                    <field name="uom_id"/>
                                    <field name="estimated_cost"/>
                                    <field name="amount_customer" attrs="{'invisible': [('assume_cost_customer', '=', False)], 'required': [('assume_cost_customer', '=', True)]}"/>
                                    <field name="amount_sidsa" attrs="{'invisible': [('assume_cost_sidsa', '=', False)], 'required': [('assume_cost_sidsa', '=', True)]}"/>
                                    <field name="amount_supplier" attrs="{'invisible': [('assume_cost_supplier', '=', False)], 'required': [('assume_cost_supplier', '=', True)]}"/>
                                    <field name="assume_cost_customer"/>
                                    <field name="assume_cost_sidsa"/>
                                    <field name="assume_cost_supplier"/>
                                </group>
                            </group>
                            <group string="Description / Evidence">
                                <field name="description" nolabel="1" placeholder="What happened? Where was it detected? What evidence exists?"/>
                            </group>
                        </page>
                        <page string="Treatment">
                            <group string="Immediate Containment">
                                <field name="containment_action" nolabel="1" placeholder="Action taken to contain the issue and avoid recurrence during investigation."/>
                            </group>
                            <group string="Root Cause">
                                <field name="root_cause" nolabel="1" placeholder="Root cause analysis. Example: 5 Whys, process failure, supplier issue, documentation mismatch."/>
                            </group>
                            <group string="Corrective Action">
                                <field name="corrective_action" nolabel="1"/>
                            </group>
                            <group string="Preventive Action / Risk Treatment">
                                <field name="preventive_action" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Verification and Close">
                            <group string="Effectiveness Check">
                                <field name="effectiveness_check" nolabel="1" placeholder="How has the action been checked? Date, evidence and result."/>
                            </group>
                            <group string="Closing Notes">
                                <field name="closing_notes" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Environmental">
                            <group string="ISO 14001 Impact / Controls">
                                <field name="environmental_impact" nolabel="1" placeholder="Environmental aspect, impact, waste, spill, packaging, transport or legal compliance issue."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_sid_nonconformity_graph" model="ir.ui.view">
        <field name="name">sid.nonconformity.graph</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <graph string="Nonconformities" type="bar">
                <field name="date_detected" interval="month"/>
                <field name="id" type="measure"/>
                <field name="nc_type"/>
            </graph>
        </field>
    </record>

    <record id="view_sid_nonconformity_pivot" model="ir.ui.view">
        <field name="name">sid.nonconformity.pivot</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <pivot string="Nonconformities">
                <field name="date_detected" interval="month" type="row"/>
                <field name="nc_type" type="col"/>
                <field name="id" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_sid_nonconformity" model="ir.actions.act_window">
        <field name="name">Nonconformities</field>
        <field name="res_model">sid.nonconformity</field>
        <field name="view_mode">tree,kanban,form,graph,pivot</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create the first nonconformity</p>
            <p>Track supplier, customer, logistics, product, process and environmental nonconformities with ISO 9001/14001 evidence.</p>
        </field>
    </record>
</odoo>
