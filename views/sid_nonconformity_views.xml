<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sid_nonconformity_tree" model="ir.ui.view">
        <field name="name">sid.nonconformity.tree</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <tree decoration-danger="is_overdue" decoration-muted="state in ('done', 'cancel')">
                <field name="name"/>
                <field name="title"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state in ('open', 'action', 'verify')" decoration-warning="state == 'draft'" decoration-danger="state == 'cancel'"/>
                <field name="nc_type"/>
                <field name="iso_scope"/>
                <field name="severity"/>
                <field name="priority"/>
                <field name="supplier_id"/>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <field name="reviewer_id"/>
                <field name="date_detected"/>
                <field name="date_deadline"/>
                <field name="is_overdue"/>
            </tree>
        </field>
    </record>

    <record id="view_sid_nonconformity_kanban" model="ir.ui.view">
        <field name="name">sid.nonconformity.kanban</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="title"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="severity"/>
                <field name="supplier_id"/>
                <field name="customer_id"/>
                <field name="user_id"/>
                <field name="date_deadline"/>
                <field name="is_overdue"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record #{record.is_overdue.raw_value ? 'oe_kanban_color_2' : ''}">
                            <strong><field name="name"/> - <field name="title"/></strong>
                            <div><field name="nc_type"/> / <field name="severity"/></div>
                            <div t-if="record.supplier_id.raw_value"><field name="supplier_id"/></div>
                            <div t-if="record.customer_id.raw_value"><field name="customer_id"/></div>
                            <div t-if="record.date_deadline.raw_value">Fecha límite: <field name="date_deadline"/></div>
                            <div class="oe_kanban_footer">
                                <field name="user_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sid_nonconformity_search" model="ir.ui.view">
        <field name="name">sid.nonconformity.search</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
                <field name="supplier_id"/>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="purchase_id" domain="[('partner_id', '=', supplier_id)]"/>
                <field name="available_sale_order_ids" invisible="1"/>
                <field name="sale_id" domain="[('id', 'in', available_sale_order_ids)]"/>
                <field name="available_picking_ids" invisible="1"/>
                <field name="picking_id" domain="[('id', 'in', available_picking_ids)]"/>
                <filter name="open" string="Abierta(s)" domain="[('state', 'not in', ('done', 'cancel'))]"/>
                <filter name="overdue" string="Vencidas" domain="[('is_overdue', '=', True)]"/>
                <filter name="my_nc" string="Mis NC" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="iso9001" string="ISO 9001" domain="[('iso_scope', 'in', ('iso_9001', 'integrated'))]"/>
                <filter name="iso14001" string="ISO 14001" domain="[('iso_scope', 'in', ('iso_14001', 'integrated'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Tipo" context="{'group_by': 'nc_type'}"/>
                    <filter name="group_supplier" string="Proveedor" context="{'group_by': 'supplier_id'}"/>
                    <filter name="group_customer" string="Cliente" context="{'group_by': 'customer_id'}"/>
                    <filter name="group_responsible" string="Responsable" context="{'group_by': 'user_id'}"/>
                    <filter name="group_month" string="Mes de detección" context="{'group_by': 'date_detected:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sid_nonconformity_form" model="ir.ui.view">
        <field name="name">sid.nonconformity.form</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <form string="No conformidad">
                <header>
                    <button name="action_open" type="object" string="Abrir" states="draft" class="oe_highlight"/>
                    <button name="action_start_action" type="object" string="Iniciar acción correctiva" states="open" class="oe_highlight"/>
                    <button name="action_verify" type="object" string="Verificar eficacia" states="action" class="oe_highlight"/>
                    <button name="action_close" type="object" string="Cerrar" states="action,verify" class="oe_highlight"/>
                    <button name="action_cancel" type="object" string="Cancelar" states="draft,open,action,verify"/>
                    <button name="action_previous_phase" type="object" string="Fase anterior" states="open,action,verify,done"/>
                    <button name="%(action_report_sid_nonconformity_internal)d" type="action" string="Imprimir PDF de fase" class="btn-secondary"/>
                    <button name="action_reset_to_draft" type="object" string="Reiniciar a borrador" states="cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,action,verify,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attachments" type="object" class="oe_stat_button" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo" string="Adjuntos"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h2><field name="title" placeholder="Descripción breve de la no conformidad"/></h2>
                    </div>
                    <group>
                        <group string="Clasificación">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="iso_scope"/>
                            <field name="nc_type"/>
                            <field name="severity"/>
                            <field name="priority"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                        <group string="Responsabilidades y fechas">
                            <field name="user_id"/>
                            <field name="reviewer_id"/>
                            <field name="date_detected"/>
                            <field name="date_deadline"/>
                            <field name="date_closed" readonly="1"/>
                            <field name="days_to_close" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Origen">
                            <group string="Descripción / Evidencia">
                                <field name="description" nolabel="1" placeholder="¿Qué ocurrió? ¿Dónde se detectó? ¿Qué evidencia existe?"/>
                            </group>
                            <group>
                                <group string="Enlaces operativos">
                                    <field name="supplier_id"/>
                                    <field name="customer_id"/>
                                    <field name="purchase_id" domain="[('partner_id', '=', supplier_id)]"/>
                                    <field name="available_sale_order_ids" invisible="1"/>
                                    <field name="sale_id" domain="[('id', 'in', available_sale_order_ids)]"/>
                                    <field name="available_picking_ids" invisible="1"/>
                                    <field name="picking_id" domain="[('id', 'in', available_picking_ids)]"/>
                                    <field name="move_line_id" domain="[('picking_id', '=', picking_id)]"/>
                                </group>
                                <group string="Producto / Impacto">
                                    <field name="product_id"/>
                                    <field name="lot_id" domain="[('product_id', '=', product_id)]"/>
                                    <field name="quantity_affected"/>
                                    <field name="uom_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Costes">
                            <group>
                                <group string="Estimación y reparto de coste">
                                    <field name="estimated_cost"/>
                                    <field name="assume_cost_customer"/>
                                    <field name="amount_customer" attrs="{'invisible': [('assume_cost_customer', '=', False)], 'required': [('assume_cost_customer', '=', True)]}"/>
                                    <field name="assume_cost_sidsa"/>
                                    <field name="amount_sidsa" attrs="{'invisible': [('assume_cost_sidsa', '=', False)], 'required': [('assume_cost_sidsa', '=', True)]}"/>
                                    <field name="assume_cost_supplier"/>
                                    <field name="amount_supplier" attrs="{'invisible': [('assume_cost_supplier', '=', False)], 'required': [('assume_cost_supplier', '=', True)]}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Tratamiento">
                            <group string="Contención inmediata">
                                <field name="containment_action" nolabel="1" placeholder="Acción tomada para contener el problema y evitar recurrencia durante la investigación."/>
                            </group>
                            <group string="Causa raíz">
                                <field name="root_cause" nolabel="1" placeholder="Análisis de causa raíz. Ejemplo: 5 porqués, fallo de proceso, incidencia de proveedor o desajuste documental."/>
                            </group>
                            <group string="Acción correctiva">
                                <field name="corrective_action" nolabel="1"/>
                            </group>
                            <group string="Acción preventiva / Tratamiento del riesgo">
                                <field name="preventive_action" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Verificación y cierre">
                            <group string="Verificación de eficacia">
                                <field name="effectiveness_check" nolabel="1" placeholder="¿Cómo se verificó la acción? Fecha, evidencia y resultado."/>
                            </group>
                            <group string="Notas de cierre">
                                <group string="Notas internas" col="1">
                                    <field name="closing_notes_internal" widget="html" nolabel="1"/>
                                </group>
                                <group string="Notas para cliente" col="1">
                                    <field name="closing_notes_customer" widget="html" nolabel="1"/>
                                </group>
                                <group string="Notas para proveedor" col="1">
                                    <field name="closing_notes_supplier" widget="html" nolabel="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Ambiental">
                            <group string="Impacto ISO 14001 / Controles">
                                <field name="environmental_impact" nolabel="1" placeholder="Aspecto ambiental, impacto, residuo, derrame, embalaje, transporte o incumplimiento legal."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_sid_nonconformity_graph" model="ir.ui.view">
        <field name="name">sid.nonconformity.graph</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <graph string="No conformidades" type="bar">
                <field name="date_detected" interval="month"/>
                <field name="id" type="measure"/>
                <field name="nc_type"/>
            </graph>
        </field>
    </record>

    <record id="view_sid_nonconformity_pivot" model="ir.ui.view">
        <field name="name">sid.nonconformity.pivot</field>
        <field name="model">sid.nonconformity</field>
        <field name="arch" type="xml">
            <pivot string="No conformidades">
                <field name="date_detected" interval="month" type="row"/>
                <field name="nc_type" type="col"/>
                <field name="id" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_sid_nonconformity" model="ir.actions.act_window">
        <field name="name">No conformidades</field>
        <field name="res_model">sid.nonconformity</field>
        <field name="view_mode">tree,kanban,form,graph,pivot</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crear la primera no conformidad</p>
            <p>Seguimiento de no conformidades de proveedor, cliente, logística, producto, proceso y ambientales con evidencias ISO 9001/14001.</p>
        </field>
    </record>
</odoo>
